---
import { skills, experience } from "../../config/about.json";
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";

// "Mark OS" — the About page as a personal control plane: a 3D tech
// constellation (three.js) over a status-board view of skills (services),
// career (deployments) and a live uptime counter. Preview route: /about-os.

const TECH = [
  "React", "TypeScript", "Node.js", "Rails", "GraphQL", "React Native",
  "Kubernetes", "Docker", "AWS", "CI/CD", "SQL", "NoSQL", "TDD", "Astro",
];
---

<Layout title="Mark OS" description="Mark Morcos — a system: skills, career and stack as a personal control plane.">
  <Navigation />

  <main class="py-8 text-[#E6EBF0]">
    <!-- hero: 3D constellation -->
    <section class="relative overflow-hidden rounded-2xl border border-[#1d2530] bg-[#0C0F13]">
      <div
        class="pointer-events-none absolute inset-0 opacity-[0.35]"
        style="background-image:linear-gradient(#16202a 1px,transparent 1px),linear-gradient(90deg,#16202a 1px,transparent 1px);background-size:42px 42px;mask-image:radial-gradient(80% 70% at 50% 30%,#000,transparent 80%);-webkit-mask-image:radial-gradient(80% 70% at 50% 30%,#000,transparent 80%)"
      >
      </div>

      <canvas id="constellation" class="block h-[420px] w-full" aria-hidden="true"></canvas>

      <div class="pointer-events-none absolute inset-x-0 top-0 flex items-center justify-between p-4 font-mono text-[11px] tracking-[0.14em] text-[#7E8CA0]">
        <span class="flex items-center gap-2">
          <span class="inline-block h-1.5 w-1.5 rounded-full bg-[#46E0A0]"></span>
          MARK<span class="text-[#5BD6D0]">·</span>OS
        </span>
        <span>uptime <span id="uptime" class="text-[#E6EBF0]">—</span></span>
      </div>

      <div class="pointer-events-none absolute bottom-0 left-0 p-5 sm:p-7">
        <h1 class="text-3xl font-bold tracking-tight sm:text-5xl">Mark Morcos</h1>
        <p class="mt-1 font-mono text-[12.5px] text-[#9FB0C0]">
          senior software engineer · a system you can read
        </p>
        <p class="mt-1 font-mono text-[11px] text-[#5C6672]">drag the constellation ↻</p>
      </div>
    </section>

    <!-- status board -->
    <div class="mt-6 grid grid-cols-1 gap-5 lg:grid-cols-2">
      <!-- services (skills) -->
      <section class="rounded-2xl border border-[#1d2530] bg-[#0e1318] p-5">
        <div class="mb-4 font-mono text-[11px] tracking-[0.12em] text-[#7E8CA0]">// SERVICES</div>
        <div class="flex flex-col gap-3">
          {skills.map((s) => (
            <div class="flex items-center gap-3">
              <span class="inline-block h-2 w-2 flex-none rounded-full bg-[#46E0A0] shadow-[0_0_10px_#46E0A0aa]"></span>
              <span class="w-40 flex-none font-mono text-[13px] text-[#E6EBF0]">{s.title}</span>
              <span class="font-mono text-[12px] text-[#7E8CA0]">{s.description}</span>
            </div>
          ))}
        </div>
        <div class="mt-5 mb-2 font-mono text-[11px] tracking-[0.12em] text-[#7E8CA0]">// NOW</div>
        <div class="font-mono text-[12.5px] leading-relaxed text-[#9FB0C0]">
          running a Raspberry-Pi k3s homelab · building an Admin OS control plane ·
          learning German · open to interesting problems.
        </div>
      </section>

      <!-- deployments (experience) -->
      <section class="rounded-2xl border border-[#1d2530] bg-[#0e1318] p-5">
        <div class="mb-4 font-mono text-[11px] tracking-[0.12em] text-[#7E8CA0]">// DEPLOYMENTS</div>
        <ol class="relative flex flex-col gap-4 border-l border-[#1d2530] pl-5">
          {experience.map((e, i) => (
            <li class="relative">
              <span
                class={`absolute -left-[26px] top-1 h-2.5 w-2.5 rounded-full ${i === 0 ? "bg-[#5BD6D0] shadow-[0_0_10px_#5BD6D0aa]" : "bg-[#3a4654]"}`}
              ></span>
              <div class="flex flex-wrap items-baseline gap-x-2">
                <span class="font-mono text-[13.5px] font-semibold text-[#E6EBF0]">{e.company}</span>
                <span class={`font-mono text-[10.5px] ${i === 0 ? "text-[#5BD6D0]" : "text-[#46E0A0]"}`}>
                  {i === 0 ? "▸ running" : "✓ shipped"}
                </span>
                <span class="ml-auto font-mono text-[11px] text-[#5C6672]">{e.period}</span>
              </div>
              <div class="font-mono text-[11.5px] text-[#9FB0C0]">{e.role}</div>
              <div class="mt-1.5 flex flex-wrap gap-1.5">
                {e.skills.slice(0, 5).map((sk) => (
                  <span class="rounded-md bg-[#141b22] px-2 py-0.5 font-mono text-[10px] text-[#7E8CA0]">{sk}</span>
                ))}
              </div>
            </li>
          ))}
        </ol>
      </section>
    </div>
  </main>
</Layout>

<script type="application/json" id="tech-data" set:html={JSON.stringify(TECH)}></script>
<script>
  const TECH = JSON.parse(
    document.getElementById("tech-data")?.textContent || "[]"
  );
  // Live uptime since the start of the journey (career ~Sep 2012).
  const start = new Date("2012-09-01T00:00:00Z").getTime();
  const el = document.getElementById("uptime");
  function tick() {
    if (!el) return;
    const s = Math.floor((Date.now() - start) / 1000);
    const y = Math.floor(s / 31557600);
    const d = Math.floor((s % 31557600) / 86400);
    const hms = new Date(s * 1000).toISOString().substr(11, 8);
    el.textContent = `${y}y ${d}d ${hms}`;
  }
  tick();
  setInterval(tick, 1000);

  // 3D tech constellation.
  (async () => {
    const canvas = document.getElementById("constellation");
    if (!canvas) return;
    let THREE, OrbitControls;
    try {
      THREE = await import("three");
      ({ OrbitControls } = await import("three/examples/jsm/controls/OrbitControls.js"));
    } catch (e) {
      return; // graceful: the status board still renders without 3D
    }

    const PRIMARY = 0x5bd6d0;
    const scene = new THREE.Scene();
    const group = new THREE.Group();
    scene.add(group);

    const camera = new THREE.PerspectiveCamera(50, 1, 0.1, 1000);
    camera.position.set(0, 0, 26);

    const renderer = new THREE.WebGLRenderer({ canvas, antialias: true, alpha: true });
    renderer.setPixelRatio(Math.min(window.devicePixelRatio, 2));

    const controls = new OrbitControls(camera, canvas);
    controls.enableDamping = true;
    controls.dampingFactor = 0.08;
    controls.enablePan = false;
    controls.enableZoom = false;
    controls.autoRotate = true;
    controls.autoRotateSpeed = 0.9;

    // Fibonacci-sphere positions for the nodes.
    const R = 10;
    const positions = [];
    const N = TECH.length;
    for (let i = 0; i < N; i++) {
      const phi = Math.acos(1 - (2 * (i + 0.5)) / N);
      const theta = Math.PI * (1 + Math.sqrt(5)) * i;
      positions.push(
        new THREE.Vector3(
          R * Math.sin(phi) * Math.cos(theta),
          R * Math.sin(phi) * Math.sin(theta),
          R * Math.cos(phi)
        )
      );
    }

    // Node dots.
    const dotGeo = new THREE.SphereGeometry(0.16, 12, 12);
    const dotMat = new THREE.MeshBasicMaterial({ color: PRIMARY });
    positions.forEach((p) => {
      const m = new THREE.Mesh(dotGeo, dotMat);
      m.position.copy(p);
      group.add(m);
    });

    // Text label sprites.
    function labelSprite(text) {
      const c = document.createElement("canvas");
      const ctx = c.getContext("2d");
      const fs = 48;
      ctx.font = `600 ${fs}px ui-monospace, monospace`;
      const w = Math.ceil(ctx.measureText(text).width) + 28;
      c.width = w; c.height = 70;
      ctx.font = `600 ${fs}px ui-monospace, monospace`;
      ctx.fillStyle = "rgba(230,235,240,0.92)";
      ctx.textBaseline = "middle";
      ctx.fillText(text, 14, 38);
      const tex = new THREE.CanvasTexture(c);
      tex.anisotropy = 4;
      const sp = new THREE.Sprite(new THREE.SpriteMaterial({ map: tex, transparent: true, depthWrite: false }));
      sp.scale.set((w / 70) * 1.7, 1.7, 1);
      return sp;
    }
    positions.forEach((p, i) => {
      const sp = labelSprite(TECH[i]);
      sp.position.copy(p).multiplyScalar(1.16);
      group.add(sp);
    });

    // Edges: connect each node to its 2 nearest neighbours.
    const linePts = [];
    positions.forEach((p, i) => {
      const near = positions
        .map((q, j) => ({ j, d: p.distanceTo(q) }))
        .filter((o) => o.j !== i)
        .sort((a, b) => a.d - b.d)
        .slice(0, 2);
      near.forEach((o) => { linePts.push(p, positions[o.j]); });
    });
    const lineGeo = new THREE.BufferGeometry().setFromPoints(linePts);
    const lines = new THREE.LineSegments(
      lineGeo,
      new THREE.LineBasicMaterial({ color: PRIMARY, transparent: true, opacity: 0.22 })
    );
    group.add(lines);

    function resize() {
      const w = canvas.clientWidth, h = canvas.clientHeight;
      if (!w || !h) return;
      renderer.setSize(w, h, false);
      camera.aspect = w / h;
      camera.updateProjectionMatrix();
    }
    resize();
    window.addEventListener("resize", resize);

    function animate() {
      requestAnimationFrame(animate);
      controls.update();
      renderer.render(scene, camera);
    }
    animate();
  })();
</script>
