---
import { skills, experience, education } from "../../config/about.json";
import Layout from "../layouts/Layout.astro";
import Navigation from "../components/Navigation.astro";

// Scrollytelling About — career as a journey. Milestones reveal on scroll and a
// central spine fills with progress. Preview route: /about-journey.

const yearOf = (s: string) => (s.match(/\d{4}/) ?? ["—"])[0];

const grad = education.find((e) => e.year === "2012");

type Milestone = {
  year: string;
  heading: string;
  sub: string;
  body: string;
  tags: string[];
  now?: boolean;
};

const milestones: Milestone[] = [
  ...(grad
    ? [{
        year: "2012",
        heading: grad.degree,
        sub: `${grad.institution} · ${grad.location}`,
        body: grad.details ?? "Where it started.",
        tags: ["C", "Java", "Algorithms"],
      }]
    : []),
  // experience is newest-first in config; reverse to walk forward in time.
  ...[...experience].reverse().map((e) => ({
    year: yearOf(e.period),
    heading: e.company,
    sub: `${e.role} · ${e.period}`,
    body: e.description,
    tags: e.skills.slice(0, 6),
    now: /present/i.test(e.period),
  })),
];
---

<Layout title="Journey" description="Mark Morcos — a journey in software, from Cairo to Berlin.">
  <Navigation />

  <main>
    <!-- intro -->
    <section class="flex min-h-[68vh] flex-col justify-center">
      <p class="font-mono text-sm tracking-widest text-indigo-500 dark:text-indigo-400">// THE JOURNEY</p>
      <h1 class="mt-3 text-4xl font-bold tracking-tight text-gray-900 dark:text-white sm:text-6xl">
        From Cairo to Berlin,<br />one commit at a time.
      </h1>
      <p class="mt-6 max-w-2xl text-lg leading-8 text-gray-600 dark:text-gray-300">
        A software engineer's path — the schools, the companies, the things
        built along the way. Scroll to follow it.
      </p>
      <div class="mt-12 flex items-center gap-2 font-mono text-sm text-gray-400 dark:text-gray-500">
        <span>scroll</span>
        <span class="animate-bounce">↓</span>
      </div>
    </section>

    <!-- timeline -->
    <section id="timeline" class="relative pb-24">
      <!-- spine -->
      <div class="absolute bottom-0 left-4 top-0 w-px bg-gray-200 dark:bg-gray-800 md:left-1/2"></div>
      <div
        id="spine-fill"
        class="absolute left-4 top-0 h-0 w-px bg-gradient-to-b from-indigo-500 to-indigo-300 md:left-1/2"
      ></div>

      <ol class="space-y-16 md:space-y-28">
        {milestones.map((m, i) => (
          <li
            class={`reveal relative pl-12 md:w-1/2 md:pl-0 ${
              i % 2 === 0
                ? "md:ml-0 md:pr-14 md:text-right"
                : "md:ml-auto md:pl-14"
            }`}
            data-side={i % 2 === 0 ? "left" : "right"}
          >
            <!-- node -->
            <span
              class={`absolute top-1.5 z-10 flex h-3.5 w-3.5 items-center justify-center rounded-full ring-4 ring-white dark:ring-gray-900 left-[9px] md:left-auto ${
                i % 2 === 0 ? "md:-right-[7px]" : "md:-left-[7px]"
              } ${m.now ? "bg-indigo-500" : "bg-gray-400 dark:bg-gray-600"}`}
            >
              {m.now && <span class="absolute h-3.5 w-3.5 animate-ping rounded-full bg-indigo-500 opacity-60"></span>}
            </span>

            <div class="text-5xl font-black tracking-tighter text-gray-200 dark:text-gray-800 sm:text-6xl">
              {m.year}
            </div>
            <h3 class="-mt-3 text-2xl font-bold text-gray-900 dark:text-white">
              {m.heading}
              {m.now && (
                <span class="ml-2 align-middle font-mono text-xs font-medium text-indigo-500">● now</span>
              )}
            </h3>
            <p class="mt-1 font-mono text-sm text-gray-500 dark:text-gray-400">{m.sub}</p>
            <p class="mt-3 max-w-md text-gray-600 dark:text-gray-300 md:inline-block">{m.body}</p>
            <div class={`mt-4 flex flex-wrap gap-2 ${i % 2 === 0 ? "md:justify-end" : ""}`}>
              {m.tags.map((t) => (
                <span class="rounded-full bg-gray-100 px-2.5 py-1 text-xs font-medium text-gray-600 dark:bg-gray-800 dark:text-gray-300">
                  {t}
                </span>
              ))}
            </div>
          </li>
        ))}
      </ol>
    </section>

    <!-- the stack (closing) -->
    <section class="reveal border-t border-gray-100 py-20 dark:border-gray-800">
      <p class="font-mono text-sm tracking-widest text-indigo-500 dark:text-indigo-400">// THE STACK TODAY</p>
      <div class="mt-8 grid grid-cols-1 gap-6 sm:grid-cols-3">
        {skills.map((s) => (
          <div class="rounded-2xl border border-gray-100 p-6 dark:border-gray-800">
            <div class="text-3xl">{s.icon}</div>
            <h3 class="mt-3 text-lg font-semibold text-gray-900 dark:text-white">{s.title}</h3>
            <p class="mt-1 text-sm text-gray-600 dark:text-gray-300">{s.description}</p>
          </div>
        ))}
      </div>
    </section>
  </main>
</Layout>

<style>
  .reveal {
    opacity: 0;
    transform: translateY(34px);
    transition: opacity 0.7s cubic-bezier(0.16, 1, 0.3, 1), transform 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  }
  .reveal.in {
    opacity: 1;
    transform: translateY(0);
  }
  @media (prefers-reduced-motion: reduce) {
    .reveal { opacity: 1; transform: none; transition: none; }
  }
</style>

<script>
  // Reveal each milestone as it enters the viewport.
  const io = new IntersectionObserver(
    (entries) => {
      for (const e of entries) {
        if (e.isIntersecting) {
          e.target.classList.add("in");
          io.unobserve(e.target);
        }
      }
    },
    { threshold: 0.18, rootMargin: "0px 0px -8% 0px" }
  );
  document.querySelectorAll(".reveal").forEach((el) => io.observe(el));

  // Fill the spine as the viewport centre travels through the timeline.
  const timeline = document.getElementById("timeline");
  const fill = document.getElementById("spine-fill");
  function onScroll() {
    if (!timeline || !fill) return;
    const rect = timeline.getBoundingClientRect();
    const mid = window.innerHeight * 0.5;
    const progress = (mid - rect.top) / rect.height;
    fill.style.height = `${Math.min(Math.max(progress, 0), 1) * 100}%`;
  }
  onScroll();
  window.addEventListener("scroll", onScroll, { passive: true });
  window.addEventListener("resize", onScroll);
</script>
